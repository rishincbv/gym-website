# ─── Supabase PostgreSQL (Direct connection) ─────────────────────────────────
# Supabase Dashboard → Connect → URI
# postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.sjkxsdfhppqfvhhvzzlp.supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.sjkxsdfhppqfvhhvzzlp.supabase.co:5432/postgres"

# ─── Supabase API ────────────────────────────────────────────────────────────
SUPABASE_URL="https://sjkxsdfhppqfvhhvzzlp.supabase.co"
SUPABASE_ANON_KEY="your-publishable-or-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
COOKIE_SECURE=false

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-this-access-secret-in-production
JWT_REFRESH_SECRET=change-this-refresh-secret-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Uploads ─────────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
